# ─── Application ──────────────────────────────────────
PROJECT_NAME=AI Q&A App
SECRET_KEY=change-me-to-a-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Database (MongoDB) ──────────────────────────────
# For Docker local MongoDB:
DATABASE_URL=mongodb://admin:changeme@mongo:27017/ai_qa_db?authSource=admin
# For MongoDB Atlas (uncomment and fill in):
# DATABASE_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>

MONGO_USER=admin
MONGO_PASSWORD=changeme
MONGO_DB=ai_qa_db

# ─── Redis ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Gemini (Google) ────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
# Free-friendly default model for lower exhaustion risk
GEMINI_MODEL=gemini-1.5-flash-8b
# Optional metadata
# GEMINI_PROJECT_NAME=projects/123456789012
# GEMINI_PROJECT_NUMBER=123456789012

# Optional: only needed if you still use OpenAI Whisper transcription path
OPENAI_API_KEY=

# ─── AWS S3 (optional) ──────────────────────────────
# AWS_BUCKET_NAME=my-bucket
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ─── File Uploads ────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=500
